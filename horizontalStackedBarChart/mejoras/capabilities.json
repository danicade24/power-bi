{
  "dataRoles": [
    {
      "name": "category",
      "kind": "Grouping",
      "displayName": "Indicador (nombre)",
      "description": "Nombre del KPI o indicador a mostrar en la barra"
    },
    {
      "name": "measure",
      "kind": "Measure",
      "displayName": "Valor actual",
      "description": "Valor numérico actual del indicador (posición del marcador)"
    },
    {
      "name": "period",
      "kind": "Grouping",
      "displayName": "Período (mes/año)",
      "description": "Opcional: columna de fecha o período para mostrar historial"
    },
    {
      "name": "thresholds",
      "kind": "Measure",
      "displayName": "Umbrales",
      "description": "Valores para definir los límites de los umbrales dinámicamente desde los datos"
    }
  ],

  "dataViewMappings": [
    {
      "conditions": [
        {
          "category": { "max": 1 },
          "measure": { "max": 1 },
          "period": { "max": 1 },
          "thresholds": {}
        }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": { "count": 50 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "measure" } },
            { "bind": { "to": "thresholds" } }
          ]
        }
      }
    }
  ],

  "objects": {

    "scaleSettings": {
      "displayName": "Escala",
      "properties": {
        "minValue": {
          "displayName": "Valor mínimo",
          "description": "Extremo izquierdo de la barra (ej: 0)",
          "type": { "numeric": true }
        },
        "maxValue": {
          "displayName": "Valor máximo",
          "description": "Extremo derecho de la barra (ej: 100)",
          "type": { "numeric": true }
        },
        "unit": {
          "displayName": "Unidad",
          "description": "Texto que acompaña el valor del marcador (ej: %, min, pts)",
          "type": { "text": true }
        }
      }
    },

    "orderSettings": {
      "displayName": "Orden de segmentos",
      "properties": {
        "ascending": {
          "displayName": "Ascendente (izquierda = mejor)",
          "description": "Si está activo: el primer segmento (izquierda) representa el estado más favorable",
          "type": { "bool": true }
        }
      }
    },

    "threshold1": {
      "displayName": "Umbral 1",
      "properties": {
        "value": {
          "displayName": "Valor del umbral",
          "type": { "numeric": true }
        },
        "color": {
          "displayName": "Color del segmento",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "label": {
          "displayName": "Etiqueta del segmento",
          "type": { "text": true }
        },
        "show": {
          "displayName": "Mostrar este umbral",
          "type": { "bool": true }
        }
      }
    },

    "threshold2": {
      "displayName": "Umbral 2",
      "properties": {
        "value": {
          "displayName": "Valor del umbral",
          "type": { "numeric": true }
        },
        "color": {
          "displayName": "Color del segmento",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "label": {
          "displayName": "Etiqueta del segmento",
          "type": { "text": true }
        },
        "show": {
          "displayName": "Mostrar este umbral",
          "type": { "bool": true }
        }
      }
    },

    "threshold3": {
      "displayName": "Umbral 3",
      "properties": {
        "value": {
          "displayName": "Valor del umbral",
          "type": { "numeric": true }
        },
        "color": {
          "displayName": "Color del segmento",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "label": {
          "displayName": "Etiqueta del segmento",
          "type": { "text": true }
        },
        "show": {
          "displayName": "Mostrar este umbral",
          "type": { "bool": true }
        }
      }
    },

    "threshold4": {
      "displayName": "Umbral 4",
      "properties": {
        "value": {
          "displayName": "Valor del umbral",
          "type": { "numeric": true }
        },
        "color": {
          "displayName": "Color del segmento",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "label": {
          "displayName": "Etiqueta del segmento",
          "type": { "text": true }
        },
        "show": {
          "displayName": "Mostrar este umbral",
          "type": { "bool": true }
        }
      }
    },

    "threshold5": {
      "displayName": "Umbral 5",
      "properties": {
        "value": {
          "displayName": "Valor del umbral",
          "type": { "numeric": true }
        },
        "color": {
          "displayName": "Color del segmento",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "label": {
          "displayName": "Etiqueta del segmento",
          "type": { "text": true }
        },
        "show": {
          "displayName": "Mostrar este umbral",
          "type": { "bool": true }
        }
      }
    },

    "markerSettings": {
      "displayName": "Marcador",
      "properties": {
        "color": {
          "displayName": "Color del marcador",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "width": {
          "displayName": "Grosor (px)",
          "type": { "numeric": true }
        },
        "showLabel": {
          "displayName": "Mostrar etiqueta de valor",
          "type": { "bool": true }
        }
      }
    },

    "barSettings": {
      "displayName": "Barra",
      "properties": {
        "height": {
          "displayName": "Alto de barra (px)",
          "type": { "numeric": true }
        },
        "borderRadius": {
          "displayName": "Esquinas redondeadas (px)",
          "type": { "numeric": true }
        },
        "showThresholdTicks": {
          "displayName": "Mostrar marcas de umbral",
          "type": { "bool": true }
        },
        "showLegend": {
          "displayName": "Mostrar leyenda de segmentos",
          "type": { "bool": true }
        }
      }
    },

    "labelSettings": {
      "displayName": "Etiquetas",
      "properties": {
        "fontSize": {
          "displayName": "Tamaño de fuente",
          "type": { "numeric": true }
        },
        "fontColor": {
          "displayName": "Color del texto",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "showIndicatorName": {
          "displayName": "Mostrar nombre del indicador",
          "type": { "bool": true }
        }
      }
    }

  },

  "supportsHighlight": false,
  "supportsKeyboardFocus": false,
  "sorting": {
    "default": {}
  }
}
