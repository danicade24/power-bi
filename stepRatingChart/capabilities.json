{
  "dataRoles": [
    {
      "displayName": "Fecha",
      "name": "date",
      "kind": "Grouping",
      "description": "Columna de fecha de cada cambio de rating"
    },
    {
      "displayName": "Agencia",
      "name": "agency",
      "kind": "Grouping",
      "description": "Nombre de la agencia (Fitch, Moody's, S&P, etc.)"
    },
    {
      "displayName": "Rating",
      "name": "rating",
      "kind": "Grouping",
      "description": "Valor del rating como texto (AAA, AA+, BBB-, etc.)"
    }
  ],

  "dataViewMappings": [
    {
      "conditions": [
        {
          "date":   { "max": 1 },
          "agency": { "max": 1 },
          "rating": { "max": 1 }
        }
      ],
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "date"   } },
            { "for": { "in": "agency" } },
            { "for": { "in": "rating" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 5000 } }
        }
      }
    }
  ],

  "objects": {

    "ratingLevels": {
      "displayName": "Niveles de Rating (eje Y)",
      "description": "Define los niveles en orden descendente separados por coma.",
      "properties": {
        "levels": {
          "displayName": "Niveles (orden descendente, separados por coma)",
          "type": { "text": true }
        }
      }
    },

    "ratingGroups": {
      "displayName": "Grupos del eje Y",
      "properties": {
        "group1Name":          { "displayName": "Grupo 1 — Nombre",                      "type": { "text": true } },
        "group1Levels":        { "displayName": "Grupo 1 — Niveles (separados por coma)", "type": { "text": true } },
        "group2Name":          { "displayName": "Grupo 2 — Nombre",                      "type": { "text": true } },
        "group2Levels":        { "displayName": "Grupo 2 — Niveles",                     "type": { "text": true } },
        "group3Name":          { "displayName": "Grupo 3 — Nombre",                      "type": { "text": true } },
        "group3Levels":        { "displayName": "Grupo 3 — Niveles",                     "type": { "text": true } },
        "group4Name":          { "displayName": "Grupo 4 — Nombre",                      "type": { "text": true } },
        "group4Levels":        { "displayName": "Grupo 4 — Niveles",                     "type": { "text": true } },
        "group5Name":          { "displayName": "Grupo 5 — Nombre",                      "type": { "text": true } },
        "group5Levels":        { "displayName": "Grupo 5 — Niveles",                     "type": { "text": true } },
        "showGroupLabels":     { "displayName": "Mostrar etiquetas de grupo",             "type": { "bool": true } },
        "showGroupSeparators": { "displayName": "Mostrar líneas de separación",           "type": { "bool": true } }
      }
    },

    "seriesSettings": {
      "displayName": "Series",
      "properties": {
        "lineWidth":  { "displayName": "Grosor de línea (px)", "type": { "numeric": true } },
        "showDots":   { "displayName": "Mostrar puntos (vértices)", "type": { "bool": true } },
        "dotRadius":  { "displayName": "Radio de nodos", "type": { "numeric": true } },
        "showLegend": { "displayName": "Mostrar leyenda",      "type": { "bool":    true } },
        "legendPosition": {
          "displayName": "Posición de leyenda",
          "type": {
            "enumeration": [
              { "value": "bottom", "displayName": "Abajo"   },
              { "value": "top",    "displayName": "Arriba"  },
              { "value": "right",  "displayName": "Derecha" }
            ]
          }
        }
      }
    },

    "seriesColors": {
      "displayName": "Colores de Agencias",
      "properties": {
        "color1": { "displayName": "Agencia 1", "type": { "fill": { "solid": { "color": true } } } },
        "color2": { "displayName": "Agencia 2", "type": { "fill": { "solid": { "color": true } } } },
        "color3": { "displayName": "Agencia 3", "type": { "fill": { "solid": { "color": true } } } },
        "color4": { "displayName": "Agencia 4", "type": { "fill": { "solid": { "color": true } } } },
        "color5": { "displayName": "Agencia 5", "type": { "fill": { "solid": { "color": true } } } },
        "color6": { "displayName": "Agencia 6", "type": { "fill": { "solid": { "color": true } } } },
        "color7": { "displayName": "Agencia 7", "type": { "fill": { "solid": { "color": true } } } },
        "color8": { "displayName": "Agencia 8", "type": { "fill": { "solid": { "color": true } } } },
        "color9": { "displayName": "Agencia 9", "type": { "fill": { "solid": { "color": true } } } },
        "color10": { "displayName": "Agencia 10", "type": { "fill": { "solid": { "color": true } } } }
      }
    },

    "axisSettings": {
      "displayName": "Eje X",
      "properties": {
        "dateFormat": {
          "displayName": "Formato de fecha",
          "type": {
            "enumeration": [
              { "value": "dd/mm/yyyy", "displayName": "dd/mm/yyyy" },
              { "value": "mm/yyyy",    "displayName": "mm/yyyy"    },
              { "value": "yyyy",       "displayName": "Solo año"   }
            ]
          }
        },
        "fontSize":  { "displayName": "Tamaño fuente", "type": { "numeric": true } },
        "fontColor": { "displayName": "Color fuente",  "type": { "fill": { "solid": { "color": true } } } },
        "maxTicks":  { "displayName": "Máx. etiquetas","type": { "numeric": true } }
      }
    },

    "yAxisSettings": {
      "displayName": "Eje Y",
      "properties": {
        "fontSize":        { "displayName": "Tamaño fuente niveles", "type": { "numeric": true } },
        "fontColor":       { "displayName": "Color fuente principal",  "type": { "fill": { "solid": { "color": true } } } },
        "secondaryFontColor": { "displayName": "Color fuente (paréntesis)", "type": { "fill": { "solid": { "color": true } } } },
        "labelStyle": {
          "displayName": "Estilo de Etiqueta",
          "type": {
            "enumeration": [
              { "value": "Standard", "displayName": "Standard (S&P / Fitch)" },
              { "value": "Moodys", "displayName": "Moody's" },
              { "value": "Both", "displayName": "Ambos" }
            ]
          }
        },
        "groupFontSize":   { "displayName": "Tamaño fuente grupos",  "type": { "numeric": true } },
        "groupFontColor":  { "displayName": "Color fuente grupos",   "type": { "fill": { "solid": { "color": true } } } },
        "showDottedLines": { "displayName": "Líneas punteadas por nivel", "type": { "bool": true } }
      }
    }

  },

  "supportsHighlight": false,
  "supportsKeyboardFocus": false,
  "sorting": { "default": {} },
  "privileges": []
}