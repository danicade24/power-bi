{
  "dataRoles": [
    {
      "displayName": "Date",
      "name": "date",
      "kind": "Grouping",
      "description": "Columna de fecha de cada cambio de rating"
    },
    {
      "displayName": "Agency",
      "name": "agency",
      "kind": "Grouping",
      "description": "Nombre de la agencia (Fitch, Moody's, S&P, etc.)"
    },
    {
      "displayName": "Rating",
      "name": "rating",
      "kind": "Grouping",
      "description": "Valor del rating como texto (AAA, AA+, BBB-, etc.)"
    },
    {
      "displayName": "Client",
      "name": "country",
      "kind": "Grouping",
      "description": "Campo de país — si se arrastra, cada país tendrá su propia línea. Con múltiples agencias se promedia el rating por país y fecha."
    },
    {
      "displayName": "Legend",
      "name": "legend",
      "kind": "Grouping",
      "description": "Leyenda del gráfico"
    }
  ],

  "dataViewMappings": [
    {
      "conditions": [
        {
          "date":    { "max": 1 },
          "agency":  { "max": 1 },
          "rating":  { "max": 1 },
          "country": { "max": 1 }
        }
      ],
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "date"    } },
            { "for": { "in": "agency"  } },
            { "for": { "in": "rating"  } },
            { "for": { "in": "country" } }
          ],
          "dataReductionAlgorithm": { "window": { "count": 30000 } }
        }
      }
    }
  ],

  "objects": {

    "ratingLevels": {
      "displayName": "Niveles de Rating (eje Y)",
      "properties": {
        "levels": { "displayName": "Niveles (orden descendente, separados por coma)", "type": { "text": true } }
      }
    },

    "ratingGroups": {
      "displayName": "Grupos del eje Y",
      "properties": {
        "group1Name":          { "displayName": "Grupo 1 — Nombre",   "type": { "text": true } },
        "group1Levels":        { "displayName": "Grupo 1 — Niveles",  "type": { "text": true } },
        "group2Name":          { "displayName": "Grupo 2 — Nombre",   "type": { "text": true } },
        "group2Levels":        { "displayName": "Grupo 2 — Niveles",  "type": { "text": true } },
        "group3Name":          { "displayName": "Grupo 3 — Nombre",   "type": { "text": true } },
        "group3Levels":        { "displayName": "Grupo 3 — Niveles",  "type": { "text": true } },
        "group4Name":          { "displayName": "Grupo 4 — Nombre",   "type": { "text": true } },
        "group4Levels":        { "displayName": "Grupo 4 — Niveles",  "type": { "text": true } },
        "group5Name":          { "displayName": "Grupo 5 — Nombre",   "type": { "text": true } },
        "group5Levels":        { "displayName": "Grupo 5 — Niveles",  "type": { "text": true } },
        "showGroupLabels":     { "displayName": "Mostrar etiquetas de grupo",   "type": { "bool": true } },
        "showGroupSeparators": { "displayName": "Mostrar líneas de separación", "type": { "bool": true } }
      }
    },

    "seriesSettings": {
      "displayName": "Series",
      "properties": {
        "lineWidth":      { "displayName": "Grosor de línea (px)", "type": { "numeric": true } },
        "showDots":       { "displayName": "Mostrar puntos",       "type": { "bool":    true } },
        "dotRadius":      { "displayName": "Radio de puntos (px)", "type": { "numeric": true } },
        "showLegend":     { "displayName": "Mostrar leyenda",      "type": { "bool":    true } },
        "legendPosition": {
          "displayName": "Posición de leyenda",
          "type": {
            "enumeration": [
              { "value": "bottom", "displayName": "Abajo"   },
              { "value": "top",    "displayName": "Arriba"  },
              { "value": "right",  "displayName": "Derecha" }
            ]
          }
        }
      }
    },

    "seriesColorsSettings": {
      "displayName": "Colores de Series",
      "properties": {
        "color1":  { "displayName": "Serie 1",  "type": { "fill": { "solid": { "color": true } } } },
        "color2":  { "displayName": "Serie 2",  "type": { "fill": { "solid": { "color": true } } } },
        "color3":  { "displayName": "Serie 3",  "type": { "fill": { "solid": { "color": true } } } },
        "color4":  { "displayName": "Serie 4",  "type": { "fill": { "solid": { "color": true } } } },
        "color5":  { "displayName": "Serie 5",  "type": { "fill": { "solid": { "color": true } } } },
        "color6":  { "displayName": "Serie 6",  "type": { "fill": { "solid": { "color": true } } } },
        "color7":  { "displayName": "Serie 7",  "type": { "fill": { "solid": { "color": true } } } },
        "color8":  { "displayName": "Serie 8",  "type": { "fill": { "solid": { "color": true } } } },
        "color9":  { "displayName": "Serie 9",  "type": { "fill": { "solid": { "color": true } } } },
        "color10": { "displayName": "Serie 10", "type": { "fill": { "solid": { "color": true } } } }
      }
    },

    "axisSettings": {
      "displayName": "Eje X",
      "properties": {
        "dateFormat": {
          "displayName": "Formato de fecha",
          "type": {
            "enumeration": [
              { "value": "dd/mm/yyyy", "displayName": "dd/mm/yyyy" },
              { "value": "mm/yyyy",    "displayName": "mm/yyyy"    },
              { "value": "yyyy",       "displayName": "Solo año"   }
            ]
          }
        },
        "fontSize":  { "displayName": "Tamaño fuente", "type": { "numeric": true } },
        "fontColor": { "displayName": "Color fuente",  "type": { "fill": { "solid": { "color": true } } } },
        "maxTicks":  { "displayName": "Máx. etiquetas","type": { "numeric": true } }
      }
    },

    "yAxisSettings": {
      "displayName": "Eje Y",
      "properties": {
        "fontSize":            { "displayName": "Tamaño fuente niveles",  "type": { "numeric": true } },
        "fontColor":           { "displayName": "Color Fitch/S&P",        "type": { "fill": { "solid": { "color": true } } } },
        "secondaryFontColor":  { "displayName": "Color Moody's",          "type": { "fill": { "solid": { "color": true } } } },
        "labelStyle": {
          "displayName": "Mostrar nomenclatura",
          "type": {
            "enumeration": [
              { "value": "Both",     "displayName": "Fitch/S&P + Moody's" },
              { "value": "Standard", "displayName": "Solo Fitch/S&P"      },
              { "value": "Moodys",   "displayName": "Solo Moody's"        }
            ]
          }
        },
        "groupFontSize":   { "displayName": "Tamaño fuente grupos",      "type": { "numeric": true } },
        "groupFontColor":  { "displayName": "Color fuente grupos",       "type": { "fill": { "solid": { "color": true } } } },
        "showDottedLines": { "displayName": "Líneas punteadas por nivel", "type": { "bool":    true } }
      }
    }

  },

  "supportsHighlight": false,
  "supportsKeyboardFocus": false,
  "sorting": { "default": {} },
  "privileges": []
}