{
  "dataRoles": [
    {
      "displayName": "Grupo",
      "name": "group",
      "kind": "Grouping",
      "description": "Columna que agrupa los indicadores bajo una cabecera colapsable."
    },
    {
      "displayName": "Etiqueta (Fila)",
      "name": "label",
      "kind": "Grouping",
      "description": "Dimensión que define cada fila de la tabla."
    },
    {
      "displayName": "Valor Actual",
      "name": "measure",
      "kind": "Measure"
    },
    {
      "displayName": "Mínimo",
      "name": "min",
      "kind": "Measure"
    },
    {
      "displayName": "Máximo",
      "name": "max",
      "kind": "Measure"
    },
    {
      "displayName": "Target (Meta)",
      "name": "target",
      "kind": "Measure"
    },
    {
      "displayName": "Umbrales",
      "name": "thresholds",
      "kind": "Measure"
    },
    {
      "displayName": "Texto Formateado",
      "name": "formatText",
      "kind": "Measure"
    }
  ],

  "dataViewMappings": [
    {
      "conditions": [
        {
          "group":      { "min": 0, "max": 1 },
          "label":      { "min": 0, "max": 1 },
          "measure":    { "min": 0, "max": 1 },
          "target":     { "min": 0, "max": 1 },
          "min":        { "min": 0, "max": 1 },
          "max":        { "min": 0, "max": 1 },
          "thresholds": { "min": 0 },
          "formatText": { "min": 0, "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "bind": { "to": "group" } },
            { "bind": { "to": "label" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 1000 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "measure" } },
            { "bind": { "to": "min" } },
            { "bind": { "to": "max" } },
            { "bind": { "to": "target" } },
            { "bind": { "to": "thresholds" } },
            { "bind": { "to": "formatText" } }
          ]
        }
      }
    }
  ],

  "objects": {

    "scaleSettings": {
      "displayName": "Límites y Escala",
      "properties": {
        "minValue": { "displayName": "Valor Mínimo (Inicio)", "type": { "numeric": true } },
        "maxValue": { "displayName": "Valor Máximo (Fin)",   "type": { "numeric": true } },
        "unit":     { "displayName": "Unidad",               "type": { "text": true } }
      }
    },

    "orderSettings": {
      "displayName": "Orden de Segmentos",
      "properties": {
        "ascending":    { "displayName": "Colores Ascendentes",                  "type": { "bool": true } },
        "invertColors": { "displayName": "Invertir Solo Colores (Alternativo)",  "type": { "bool": true } }
      }
    },

    "targetSettings": {
      "displayName": "Marcador de Meta (Target)",
      "properties": {
        "show":  { "displayName": "Mostrar",      "type": { "bool": true } },
        "color": { "displayName": "Color de línea","type": { "fill": { "solid": { "color": true } } } },
        "width": { "displayName": "Grosor (px)",  "type": { "numeric": true } }
      }
    },

    "thresholdsSettings": {
      "displayName": "Configurar Umbrales Manuales",
      "properties": {
        "numThresholds": { "displayName": "¿Cuántos umbrales manuales?", "type": { "numeric": true } },
        "t1":  { "displayName": "Umbral 1",  "type": { "numeric": true } },
        "t2":  { "displayName": "Umbral 2",  "type": { "numeric": true } },
        "t3":  { "displayName": "Umbral 3",  "type": { "numeric": true } },
        "t4":  { "displayName": "Umbral 4",  "type": { "numeric": true } },
        "t5":  { "displayName": "Umbral 5",  "type": { "numeric": true } },
        "t6":  { "displayName": "Umbral 6",  "type": { "numeric": true } },
        "t7":  { "displayName": "Umbral 7",  "type": { "numeric": true } },
        "t8":  { "displayName": "Umbral 8",  "type": { "numeric": true } },
        "t9":  { "displayName": "Umbral 9",  "type": { "numeric": true } },
        "t10": { "displayName": "Umbral 10", "type": { "numeric": true } },
        "t11": { "displayName": "Umbral 11", "type": { "numeric": true } },
        "t12": { "displayName": "Umbral 12", "type": { "numeric": true } },
        "t13": { "displayName": "Umbral 13", "type": { "numeric": true } },
        "t14": { "displayName": "Umbral 14", "type": { "numeric": true } },
        "t15": { "displayName": "Umbral 15", "type": { "numeric": true } },
        "t16": { "displayName": "Umbral 16", "type": { "numeric": true } },
        "t17": { "displayName": "Umbral 17", "type": { "numeric": true } },
        "t18": { "displayName": "Umbral 18", "type": { "numeric": true } },
        "t19": { "displayName": "Umbral 19", "type": { "numeric": true } },
        "t20": { "displayName": "Umbral 20", "type": { "numeric": true } }
      }
    },

    "markerSettings": {
      "displayName": "Marcador",
      "properties": {
        "color":         { "displayName": "Color",                         "type": { "fill": { "solid": { "color": true } } } },
        "width":         { "displayName": "Alto del marcador (px)",         "type": { "numeric": true } },
        "thickness":     { "displayName": "Ancho (grosor) del marcador (px)","type": { "numeric": true } },
        "overrideValue": { "displayName": "Valor en eje X (Manual)",        "type": { "numeric": true } },
        "showLabel":     { "displayName": "Mostrar etiqueta del valor",      "type": { "bool": true } }
      }
    },

    "barSettings": {
      "displayName": "Configuración de Barra",
      "properties": {
        "height":              { "displayName": "Alto de la barra (px)",              "type": { "numeric": true } },
        "borderRadius":        { "displayName": "Esquinas redondeadas (px)",           "type": { "numeric": true } },
        "showThresholdTicks":  { "displayName": "Mostrar marcas de los umbrales",     "type": { "bool": true } },
        "showLegend":          { "displayName": "Mostrar leyenda",                    "type": { "bool": true } },
        "showLegendSigns":     { "displayName": "Signos ≥ / < en leyenda",            "type": { "bool": true } },
        "rowSpacing":          { "displayName": "Espaciado entre filas (px)",          "type": { "numeric": true } }
      }
    },

    "labelSettings": {
      "displayName": "Etiquetas Generales",
      "properties": {
        "fontSize":        { "displayName": "Tamaño de fuente",          "type": { "numeric": true } },
        "fontColor":       { "displayName": "Color de fuente",           "type": { "fill": { "solid": { "color": true } } } },
        "showIndicatorName":{ "displayName": "Mostrar nombre indicador", "type": { "bool": true } },
        "labelColWidth":   { "displayName": "Ancho columna Etiqueta (%)", "type": { "numeric": true } },
        "valueColWidth":   { "displayName": "Ancho columna Valor (%)",    "type": { "numeric": true } }
      }
    },

    "groupHeaderSettings": {
      "displayName": "Cabecera de Grupo",
      "properties": {
        "invertGroupOrder": { "displayName": "Invertir orden de grupos", "type": { "bool": true } },
        "bgColor":      { "displayName": "Color de fondo",       "type": { "fill": { "solid": { "color": true } } } },
        "fontColor":    { "displayName": "Color de texto",       "type": { "fill": { "solid": { "color": true } } } },
        "fontSize":     { "displayName": "Tamaño de fuente (px)","type": { "numeric": true } },
        "headerHeight": { "displayName": "Alto de cabecera (px)", "type": { "numeric": true } }
      }
    },

    "kpiPanelSettings": {
      "displayName": "Panel KPI (valor formateado)",
      "properties": {
        "valueFontSize": { "displayName": "Tamaño valor",          "type": { "numeric": true } },
        "labelFontSize": { "displayName": "Tamaño etiqueta",       "type": { "numeric": true } },
        "valueColor":    { "displayName": "Color del valor",       "type": { "fill": { "solid": { "color": true } } } },
        "labelColor":    { "displayName": "Color de etiqueta",     "type": { "fill": { "solid": { "color": true } } } },
        "fontFamily":    { "displayName": "Fuente",                "type": { "formatting": { "fontFamily": true } } },
        "bold":          { "displayName": "Negrita",               "type": { "bool": true } },
        "italic":        { "displayName": "Cursiva",               "type": { "bool": true } }
      }
    },

    "segmentColorsSettings": {
      "displayName": "Sobrescribir Colores de Segmentos",
      "properties": {
        "numColors": { "displayName": "Cantidad de colores manuales", "type": { "numeric": true } },
        "c1":  { "displayName": "Color 1",  "type": { "fill": { "solid": { "color": true } } } },
        "c2":  { "displayName": "Color 2",  "type": { "fill": { "solid": { "color": true } } } },
        "c3":  { "displayName": "Color 3",  "type": { "fill": { "solid": { "color": true } } } },
        "c4":  { "displayName": "Color 4",  "type": { "fill": { "solid": { "color": true } } } },
        "c5":  { "displayName": "Color 5",  "type": { "fill": { "solid": { "color": true } } } },
        "c6":  { "displayName": "Color 6",  "type": { "fill": { "solid": { "color": true } } } },
        "c7":  { "displayName": "Color 7",  "type": { "fill": { "solid": { "color": true } } } },
        "c8":  { "displayName": "Color 8",  "type": { "fill": { "solid": { "color": true } } } },
        "c9":  { "displayName": "Color 9",  "type": { "fill": { "solid": { "color": true } } } },
        "c10": { "displayName": "Color 10", "type": { "fill": { "solid": { "color": true } } } },
        "c11": { "displayName": "Color 11", "type": { "fill": { "solid": { "color": true } } } },
        "c12": { "displayName": "Color 12", "type": { "fill": { "solid": { "color": true } } } },
        "c13": { "displayName": "Color 13", "type": { "fill": { "solid": { "color": true } } } },
        "c14": { "displayName": "Color 14", "type": { "fill": { "solid": { "color": true } } } },
        "c15": { "displayName": "Color 15", "type": { "fill": { "solid": { "color": true } } } },
        "c16": { "displayName": "Color 16", "type": { "fill": { "solid": { "color": true } } } },
        "c17": { "displayName": "Color 17", "type": { "fill": { "solid": { "color": true } } } },
        "c18": { "displayName": "Color 18", "type": { "fill": { "solid": { "color": true } } } },
        "c19": { "displayName": "Color 19", "type": { "fill": { "solid": { "color": true } } } },
        "c20": { "displayName": "Color 20", "type": { "fill": { "solid": { "color": true } } } }
      }
    }

  },

  "supportsHighlight": false,
  "supportsKeyboardFocus": false,
  "tooltips": {
    "supportedTypes": { "default": true, "canvas": true },
    "roles": ["measure"]
  },
  "sorting": { "default": {} },
  "privileges": []
}
