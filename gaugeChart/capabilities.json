{
  "dataRoles": [
    {
      "displayName": "Valor Actual",
      "name": "measure",
      "kind": "Measure"
    },
    {
      "displayName": "Mínimo",
      "name": "min",
      "kind": "Measure"
    },
    {
      "displayName": "Máximo",
      "name": "max",
      "kind": "Measure"
    },
    {
      "displayName": "Target (Meta)",
      "name": "target",
      "kind": "Measure"
    },
    {
      "displayName": "Umbrales",
      "name": "thresholds",
      "kind": "Measure"
    },
    {
      "displayName": "Texto Formateado",
      "name": "formatText",
      "kind": "Measure"
    }
  ],

  "dataViewMappings": [
    {
      "conditions": [
        {
          "measure": { "min": 1, "max": 1 },
          "target": { "min": 0, "max": 1 },
          "min": { "min": 0, "max": 1 },
          "max": { "min": 0, "max": 1 },
          "thresholds": { "min": 0 },
          "formatText": { "min": 0, "max": 1 }
        }
      ],
      "categorical": {
        "values": {
          "select": [
            { "bind": { "to": "measure" } },
            { "bind": { "to": "min" } },
            { "bind": { "to": "max" } },
            { "bind": { "to": "target" } },
            { "bind": { "to": "thresholds" } },
            { "bind": { "to": "formatText" } }
          ]
        }
      }
    }
  ],

  "objects": {

    "scaleSettings": {
      "displayName": "Límites y Escala",
      "properties": {
        "minValue": {
          "displayName": "Valor Mínimo (Inicio)",
          "type": { "numeric": true }
        },
        "maxValue": {
          "displayName": "Valor Máximo (Fin)",
          "type": { "numeric": true }
        },
        "unit": {
          "displayName": "Unidad",
          "type": { "text": true }
        }
      }
    },

    "orderSettings": {
      "displayName": "Orden de Segmentos",
      "properties": {
        "ascending": {
          "displayName": "Colores Ascendentes",
          "type": { "bool": true }
        }
      }
    },

    "targetSettings": {
      "displayName": "Marcador de Meta (Target)",
      "properties": {
        "show": {
          "displayName": "Mostrar",
          "type": { "bool": true }
        },
        "color": {
          "displayName": "Color de línea",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "width": {
          "displayName": "Grosor (px)",
          "type": { "numeric": true }
        }
      }
    },

    "thresholdsSettings": {
      "displayName": "Líneas de Umbral",
      "properties": {
        "numThresholds": { "displayName": "Número de umbrales manuales", "type": { "numeric": true } },
        "t1": { "displayName": "Umbral 1", "type": { "numeric": true } },
        "t2": { "displayName": "Umbral 2", "type": { "numeric": true } },
        "t3": { "displayName": "Umbral 3", "type": { "numeric": true } },
        "t4": { "displayName": "Umbral 4", "type": { "numeric": true } },
        "t5": { "displayName": "Umbral 5", "type": { "numeric": true } },
        "t6": { "displayName": "Umbral 6", "type": { "numeric": true } },
        "t7": { "displayName": "Umbral 7", "type": { "numeric": true } },
        "t8": { "displayName": "Umbral 8", "type": { "numeric": true } },
        "t9": { "displayName": "Umbral 9", "type": { "numeric": true } },
        "t10": { "displayName": "Umbral 10", "type": { "numeric": true } },
        "t11": { "displayName": "Umbral 11", "type": { "numeric": true } },
        "t12": { "displayName": "Umbral 12", "type": { "numeric": true } },
        "t13": { "displayName": "Umbral 13", "type": { "numeric": true } },
        "t14": { "displayName": "Umbral 14", "type": { "numeric": true } },
        "t15": { "displayName": "Umbral 15", "type": { "numeric": true } },
        "t16": { "displayName": "Umbral 16", "type": { "numeric": true } },
        "t17": { "displayName": "Umbral 17", "type": { "numeric": true } },
        "t18": { "displayName": "Umbral 18", "type": { "numeric": true } },
        "t19": { "displayName": "Umbral 19", "type": { "numeric": true } },
        "t20": { "displayName": "Umbral 20", "type": { "numeric": true } }
      }
    },

    "markerSettings": {
      "displayName": "Marcador",
      "properties": {
        "color": {
          "displayName": "Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "width": {
          "displayName": "Alto del marcador (px)",
          "type": { "numeric": true }
        },
        "overrideValue": {
          "displayName": "Valor en eje X (Manual)",
          "type": { "numeric": true }
        },
        "showLabel": {
          "displayName": "Mostrar etiqueta del valor",
          "type": { "bool": true }
        }
      }
    },

    "barSettings": {
      "displayName": "Configuración de Barra",
      "properties": {
        "height": {
          "displayName": "Alto de la barra (px)",
          "type": { "numeric": true }
        },
        "borderRadius": {
          "displayName": "Esquinas redondeadas (px)",
          "type": { "numeric": true }
        },
        "showThresholdTicks": {
          "displayName": "Mostrar marcas de los umbrales",
          "type": { "bool": true }
        },
        "showLegend": {
          "displayName": "Mostrar leyenda",
          "type": { "bool": true }
        }
      }
    },

    "labelSettings": {
      "displayName": "Etiquetas Generales",
      "properties": {
        "fontSize": {
          "displayName": "Tamaño de fuente",
          "type": { "numeric": true }
        },
        "fontColor": {
          "displayName": "Color de fuente",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "showIndicatorName": {
          "displayName": "Mostrar nombre del indicador",
          "type": { "bool": true }
        },
        "kpiValueFontSize": {
          "displayName": "Tamaño valor formateado (px)",
          "type": {
            "numeric": true
          }
        },
        "kpiLabelFontSize": {
          "displayName": "Tamaño etiqueta 'Objetivo' (px)",
          "type": {
            "numeric": true
          }
        }
      }
    }

  },

  "supportsHighlight": false,
  "supportsKeyboardFocus": false,
  "sorting": {
    "default": {}
  },
  "privileges": []
}
